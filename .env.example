# .env.example — шаблон переменных окружения бота buklproxy.
# Скопируйте в .env и заполните реальными значениями. Не коммитьте .env!
# Контракт переменных: docs/04-data-contract.md §3.

# ── Telegram-бот ──────────────────────────────────────────────────────────

# Токен бота, выдаётся @BotFather
BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwXyZ

# Username бота без «@» (нужен для реферальных ссылок t.me/<BOT_USERNAME>?start=...)
BOT_USERNAME=your_vpn_bot

# ── База данных ────────────────────────────────────────────────────────────

# DSN Supabase Postgres для asyncpg
# Формат: postgresql://postgres.<project>:<password>@<host>:5432/postgres
PG_DSN=postgresql://postgres.xxxxxxxxxxxx:your_password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── VPS-агент (Node, /opt/vps-agent/, порт 3000) ──────────────────────────

# Базовый URL агента (только localhost; не менять без правки сервера)
VPS_AGENT_URL=http://127.0.0.1:3000

# Общий секретный токен — одинаков в /opt/vps-agent/.env и здесь.
# Используется ботом в заголовке «Authorization: Bearer ...»
# и агентом при отправке колбэка экспирации.
VPS_AGENT_TOKEN=replace_with_your_shared_secret_token

# ── Webhook (колбэк экспирации от агента → боту) ──────────────────────────

# Хост aiohttp-сервера бота, слушающего POST /agent/expire
WEBHOOK_HOST=127.0.0.1

# Порт aiohttp-сервера бота
# Итоговый URL: http://<WEBHOOK_HOST>:<WEBHOOK_PORT>/agent/expire
WEBHOOK_PORT=8081

# ── Переменная АГЕНТА (справочно, не читается ботом) ──────────────────────

# EXPIRE_CALLBACK_URL задаётся в /opt/vps-agent/.env, а НЕ здесь.
# Агент сам отправляет POST на этот адрес при автоэкспирации ключей.
# Значение должно совпадать с WEBHOOK_HOST/PORT выше:
# EXPIRE_CALLBACK_URL=http://127.0.0.1:8081/agent/expire
